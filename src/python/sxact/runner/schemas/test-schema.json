{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xact.dev/schemas/test-schema.json",
  "title": "sxAct test file",
  "description": "Schema for TOML-based sxAct test files. Each file runs in a fresh CAS context (per-file isolation). See specs/2026-01-22-design-framework-gaps.md §5.1, §5.4.",
  "type": "object",
  "required": ["meta"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "description": "File-level metadata",
      "type": "object",
      "required": ["id", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Unique identifier for this test file (used in reporting and snapshot naming)",
          "type": "string",
          "pattern": "^[a-z0-9_/-]+$"
        },
        "description": {
          "description": "Human-readable description of what this file tests",
          "type": "string"
        },
        "tags": {
          "description": "Categorization tags (e.g. 'xcore', 'manifold', 'critical', 'layer:1')",
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "default": []
        },
        "layer": {
          "description": "Test layer: 1=unit, 2=property, 3=performance",
          "type": "integer",
          "enum": [1, 2, 3],
          "default": 1
        },
        "oracle_is_axiom": {
          "description": "When false, mathematical law takes precedence over oracle output for assertions",
          "type": "boolean",
          "default": true
        },
        "skip": {
          "description": "If set, skip this file with the given reason",
          "type": "string"
        }
      }
    },
    "setup": {
      "description": "Ordered list of setup operations run once per file before any tests. Results stored via store_as are available to all tests.",
      "type": "array",
      "items": { "$ref": "#/$defs/operation" },
      "default": []
    },
    "tests": {
      "description": "List of test cases in this file",
      "type": "array",
      "items": { "$ref": "#/$defs/test" },
      "default": []
    }
  },
  "$defs": {
    "operation": {
      "description": "A single CAS operation within a setup or test block",
      "type": "object",
      "required": ["action"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "description": "The action to perform",
          "$ref": "#/$defs/actionName"
        },
        "store_as": {
          "description": "Bind the result of this operation to a name for later reference. Scope: setup→file-wide; test operation→test-local.",
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "args": {
          "description": "Action-specific arguments (see action vocabulary below)",
          "$ref": "#/$defs/actionArgs"
        }
      }
    },
    "actionName": {
      "type": "string",
      "enum": [
        "DefManifold",
        "DefMetric",
        "DefTensor",
        "DefBasis",
        "DefChart",
        "Evaluate",
        "ToCanonical",
        "Simplify",
        "Contract",
        "CommuteCovDs",
        "DefPerturbation",
        "CheckMetricConsistency",
        "Perturb",
        "PerturbCurvature",
        "PerturbationOrder",
        "PerturbationAtOrder",
        "IntegrateByParts",
        "TotalDerivativeQ",
        "VarD",
        "SetBasisChange",
        "ChangeBasis",
        "GetJacobian",
        "BasisChangeQ",
        "SetComponents",
        "GetComponents",
        "ComponentValue",
        "CTensorQ",
        "ToBasis",
        "FromBasis",
        "TraceBasisDummy",
        "Christoffel",
        "Assert"
      ]
    },
    "actionArgs": {
      "description": "Arguments dispatched by action type",
      "anyOf": [
        { "$ref": "#/$defs/args/DefManifold" },
        { "$ref": "#/$defs/args/DefMetric" },
        { "$ref": "#/$defs/args/DefTensor" },
        { "$ref": "#/$defs/args/DefBasis" },
        { "$ref": "#/$defs/args/DefChart" },
        { "$ref": "#/$defs/args/Evaluate" },
        { "$ref": "#/$defs/args/ToCanonical" },
        { "$ref": "#/$defs/args/Simplify" },
        { "$ref": "#/$defs/args/Contract" },
        { "$ref": "#/$defs/args/CommuteCovDs" },
        { "$ref": "#/$defs/args/DefPerturbation" },
        { "$ref": "#/$defs/args/CheckMetricConsistency" },
        { "$ref": "#/$defs/args/Perturb" },
        { "$ref": "#/$defs/args/PerturbCurvature" },
        { "$ref": "#/$defs/args/PerturbationOrder" },
        { "$ref": "#/$defs/args/PerturbationAtOrder" },
        { "$ref": "#/$defs/args/IntegrateByParts" },
        { "$ref": "#/$defs/args/TotalDerivativeQ" },
        { "$ref": "#/$defs/args/VarD" },
        { "$ref": "#/$defs/args/SetBasisChange" },
        { "$ref": "#/$defs/args/ChangeBasis" },
        { "$ref": "#/$defs/args/GetJacobian" },
        { "$ref": "#/$defs/args/BasisChangeQ" },
        { "$ref": "#/$defs/args/SetComponents" },
        { "$ref": "#/$defs/args/GetComponents" },
        { "$ref": "#/$defs/args/ComponentValue" },
        { "$ref": "#/$defs/args/CTensorQ" },
        { "$ref": "#/$defs/args/ToBasis" },
        { "$ref": "#/$defs/args/FromBasis" },
        { "$ref": "#/$defs/args/TraceBasisDummy" },
        { "$ref": "#/$defs/args/Christoffel" },
        { "$ref": "#/$defs/args/Assert" }
      ]
    },
    "test": {
      "description": "A named test case",
      "type": "object",
      "required": ["id", "description", "operations"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Unique identifier within this file",
          "type": "string",
          "pattern": "^[a-z0-9_-]+$"
        },
        "description": {
          "description": "Human-readable description of what is being tested",
          "type": "string"
        },
        "tags": {
          "description": "Test-level tags (merged with file-level tags for filtering)",
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "default": []
        },
        "dependencies": {
          "description": "IDs of other tests in this file that must run and pass before this test. Topologically sorted by the runner.",
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "uniqueItems": true,
          "default": []
        },
        "skip": {
          "description": "If set, skip this test with the given reason",
          "type": "string"
        },
        "oracle_is_axiom": {
          "description": "Override file-level oracle_is_axiom for this specific test",
          "type": "boolean"
        },
        "operations": {
          "description": "Ordered list of operations to execute for this test",
          "type": "array",
          "items": { "$ref": "#/$defs/operation" },
          "minItems": 1
        },
        "expected": {
          "description": "Expected outcome of the test (compared against the last operation result that does not use store_as, or the operation with the matching action)",
          "$ref": "#/$defs/expected"
        }
      }
    },
    "expected": {
      "description": "Expected output specification for a test. At least one field must be present.",
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "expect_error": {
          "description": "When true, the test expects an error. The test passes if the adapter returns an error or raises an exception; it fails if the operation succeeds.",
          "type": "boolean"
        },
        "expr": {
          "description": "Expected expression string in implementation-native notation. Compared after normalization (tier 1).",
          "type": "string"
        },
        "normalized": {
          "description": "Expected expression after normalization (dummy indices renamed to $1, $2, ...; terms sorted). Compared as-is (tier 1 fast path).",
          "type": "string"
        },
        "value": {
          "description": "Expected scalar value (for numeric results)",
          "type": ["number", "string"]
        },
        "is_zero": {
          "description": "Assert the result simplifies to zero via tier 2 semantic check",
          "type": "boolean"
        },
        "properties": {
          "description": "Structured properties expected on the result",
          "$ref": "#/$defs/properties"
        },
        "comparison_tier": {
          "description": "Force a minimum comparison tier (1=normalized string, 2=semantic diff=0, 3=numeric sampling). Default: use lowest tier that succeeds.",
          "type": "integer",
          "enum": [1, 2, 3]
        }
      }
    },
    "properties": {
      "description": "Structured tensor/expression properties",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rank": {
          "description": "Tensor rank (number of free indices)",
          "type": "integer",
          "minimum": 0
        },
        "symmetry": {
          "description": "Symmetry specification",
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Symmetric", "Antisymmetric", "RiemannSymmetric", "NoSymmetry"]
            },
            "slots": {
              "description": "Index slot positions the symmetry acts on (0-based)",
              "type": "array",
              "items": { "type": "integer" }
            }
          }
        },
        "manifold": {
          "description": "Name of the manifold this tensor is defined on",
          "type": "string"
        },
        "type": {
          "description": "Object type as returned by the adapter",
          "type": "string",
          "enum": ["Tensor", "Scalar", "Manifold", "Metric", "CovD", "Bool", "Expr"]
        }
      }
    },
    "args": {
      "DefManifold": {
        "description": "Arguments for DefManifold action",
        "type": "object",
        "required": ["name", "dimension", "indices"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Manifold symbol name",
            "type": "string"
          },
          "dimension": {
            "description": "Manifold dimension",
            "type": "integer",
            "minimum": 1
          },
          "indices": {
            "description": "List of index symbol names available on this manifold",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "metric_signature": {
            "description": "Metric signature as integer (e.g. -2 for Lorentzian 4D)",
            "type": "integer"
          }
        }
      },
      "DefMetric": {
        "description": "Arguments for DefMetric action",
        "type": "object",
        "required": ["signdet", "metric", "covd"],
        "additionalProperties": false,
        "properties": {
          "signdet": {
            "description": "Sign of metric determinant: +1 (Riemannian) or -1 (Lorentzian)",
            "type": "integer",
            "enum": [-1, 1]
          },
          "metric": {
            "description": "Metric tensor expression with indices, e.g. 'g[-a,-b]'",
            "type": "string"
          },
          "covd": {
            "description": "Covariant derivative operator symbol name",
            "type": "string"
          },
          "symbols": {
            "description": "Display symbols for the covariant derivative [infix, prefix], e.g. [';', '∇']",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          },
          "manifold": {
            "description": "Manifold name (resolved via store_as if omitted, uses last defined manifold)",
            "type": "string"
          }
        }
      },
      "DefTensor": {
        "description": "Arguments for DefTensor action",
        "type": "object",
        "required": ["name", "indices"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Tensor symbol name",
            "type": "string"
          },
          "indices": {
            "description": "Index slots with up/down position, e.g. ['-a', '-b'] for covariant",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[+-]?[a-zA-Z][a-zA-Z0-9]*$"
            },
            "minItems": 0
          },
          "manifold": {
            "description": "Manifold name this tensor lives on (resolved via store_as context)",
            "type": "string"
          },
          "manifolds": {
            "description": "List of manifold names for multi-index-set tensors (indices from different manifolds). Use instead of 'manifold' when indices span multiple manifolds.",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "symmetry": {
            "description": "Symmetry in xAct notation, e.g. 'Symmetric[{-a,-b}]' or 'Antisymmetric[{1,2}]'",
            "type": "string"
          },
          "weight": {
            "description": "Tensor weight for density tensors",
            "type": ["integer", "number"]
          }
        }
      },
      "DefBasis": {
        "description": "Arguments for DefBasis action",
        "type": "object",
        "required": ["name", "vbundle", "cnumbers"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Basis symbol name",
            "type": "string"
          },
          "vbundle": {
            "description": "Vector bundle this basis acts on, e.g. 'TangentM'",
            "type": "string"
          },
          "cnumbers": {
            "description": "Integer labels for basis elements, length must equal dimension",
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 1
          }
        }
      },
      "DefChart": {
        "description": "Arguments for DefChart action",
        "type": "object",
        "required": ["name", "manifold", "cnumbers", "scalars"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Chart symbol name (also becomes the coordinate basis name)",
            "type": "string"
          },
          "manifold": {
            "description": "Manifold this chart covers",
            "type": "string"
          },
          "cnumbers": {
            "description": "Integer labels for coordinates, length must equal dimension",
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 1
          },
          "scalars": {
            "description": "Coordinate scalar field names, e.g. ['t', 'r', 'theta', 'phi']",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      },
      "Evaluate": {
        "description": "Arguments for Evaluate action",
        "type": "object",
        "required": ["expression"],
        "additionalProperties": false,
        "properties": {
          "expression": {
            "description": "Expression string to evaluate in the current context",
            "type": "string"
          }
        }
      },
      "ToCanonical": {
        "description": "Arguments for ToCanonical action",
        "type": "object",
        "required": ["expression"],
        "additionalProperties": false,
        "properties": {
          "expression": {
            "description": "Expression to canonicalize",
            "type": "string"
          },
          "method": {
            "description": "Canonicalization method (adapter-specific; default: standard Butler-Portugal)",
            "type": "string"
          }
        }
      },
      "Simplify": {
        "description": "Arguments for Simplify action",
        "type": "object",
        "required": ["expression"],
        "additionalProperties": false,
        "properties": {
          "expression": {
            "description": "Expression to simplify",
            "type": "string"
          },
          "assumptions": {
            "description": "Assumptions to apply during simplification",
            "type": "string"
          },
          "depth": {
            "description": "Simplification depth (adapter-specific)",
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "Contract": {
        "description": "Arguments for Contract action",
        "type": "object",
        "required": ["expression"],
        "additionalProperties": false,
        "properties": {
          "expression": {
            "description": "Expression with repeated indices to contract",
            "type": "string"
          }
        }
      },
      "CommuteCovDs": {
        "description": "Arguments for CommuteCovDs action. Applies commutation identity: ∇_a ∇_b T = ∇_b ∇_a T + Riemann correction terms.",
        "type": "object",
        "required": ["expression", "covd", "indices"],
        "additionalProperties": false,
        "properties": {
          "expression": {
            "description": "Expression of the form 'covd[-a][covd[-b][tensor[slots]]]'",
            "type": "string"
          },
          "covd": {
            "description": "Name of the covariant derivative operator, e.g. 'CVD'",
            "type": "string"
          },
          "indices": {
            "description": "Exactly two derivative index strings to commute, e.g. ['-cva', '-cvb']",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        }
      },
      "DefPerturbation": {
        "description": "Arguments for DefPerturbation action. Registers a perturbation tensor with its background tensor and perturbation order.",
        "type": "object",
        "required": ["tensor", "background", "order"],
        "additionalProperties": false,
        "properties": {
          "tensor": {
            "description": "Name of the perturbed tensor (must be previously defined via DefTensor)",
            "type": "string"
          },
          "background": {
            "description": "Name of the background tensor being perturbed",
            "type": "string"
          },
          "order": {
            "description": "Perturbation order (≥ 1; 1 = first-order, 2 = second-order, ...)",
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "CheckMetricConsistency": {
        "description": "Arguments for CheckMetricConsistency action. Returns True if the background metric is internally consistent (symmetric, registered, rank-2).",
        "type": "object",
        "required": ["metric"],
        "additionalProperties": false,
        "properties": {
          "metric": {
            "description": "Name of the background metric tensor to check",
            "type": "string"
          }
        }
      },
      "Perturb": {
        "description": "Arguments for Perturb action. Expands a tensor expression to its perturbation at the given order using the Leibniz rule.",
        "type": "object",
        "required": ["expr", "order"],
        "additionalProperties": false,
        "properties": {
          "expr": {
            "description": "Tensor expression to perturb (bare tensor names, sums, or products)",
            "type": "string"
          },
          "order": {
            "description": "Perturbation order (≥ 1)",
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "PerturbCurvature": {
        "description": "Arguments for PerturbCurvature action. Returns first-order curvature perturbation formulas for a given metric and metric perturbation tensor.",
        "type": "object",
        "required": ["covd", "perturbation"],
        "additionalProperties": false,
        "properties": {
          "covd": {
            "description": "Name of the covariant derivative operator identifying the background metric, e.g. 'Cnd'",
            "type": "string"
          },
          "perturbation": {
            "description": "Name of the first-order metric perturbation tensor h_{ab}, e.g. 'Pertg1'",
            "type": "string"
          },
          "order": {
            "description": "Perturbation order (currently only 1 is supported)",
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "key": {
            "description": "Which formula to return: 'Christoffel1', 'Riemann1', 'Ricci1', or 'RicciScalar1'. When omitted, all formulas are returned.",
            "type": "string",
            "enum": ["Christoffel1", "Riemann1", "Ricci1", "RicciScalar1"]
          }
        }
      },
      "PerturbationOrder": {
        "description": "Arguments for PerturbationOrder action. Returns the perturbation order of a registered perturbation tensor.",
        "type": "object",
        "required": ["tensor"],
        "additionalProperties": false,
        "properties": {
          "tensor": {
            "description": "Name of the registered perturbation tensor",
            "type": "string"
          }
        }
      },
      "PerturbationAtOrder": {
        "description": "Arguments for PerturbationAtOrder action. Returns the name of the perturbation tensor registered for a background tensor at a given order.",
        "type": "object",
        "required": ["background", "order"],
        "additionalProperties": false,
        "properties": {
          "background": {
            "description": "Name of the background tensor",
            "type": "string"
          },
          "order": {
            "description": "Perturbation order to query (≥ 1)",
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "SetBasisChange": {
        "description": "Arguments for SetBasisChange action. Registers a coordinate transformation between two bases.",
        "type": "object",
        "required": ["from_basis", "to_basis", "matrix"],
        "additionalProperties": false,
        "properties": {
          "from_basis": {
            "description": "Source basis name",
            "type": "string"
          },
          "to_basis": {
            "description": "Target basis name",
            "type": "string"
          },
          "matrix": {
            "description": "Transformation matrix as list of lists (rows)",
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" }
            },
            "minItems": 1
          }
        }
      },
      "ChangeBasis": {
        "description": "Arguments for ChangeBasis action. Applies a basis change to a specific slot of a component array.",
        "type": "object",
        "required": ["expr", "slot", "from_basis", "to_basis"],
        "additionalProperties": false,
        "properties": {
          "expr": {
            "description": "Julia expression evaluating to the component array",
            "type": "string"
          },
          "slot": {
            "description": "1-indexed slot to transform",
            "type": "integer",
            "minimum": 1
          },
          "from_basis": {
            "description": "Current basis of that slot",
            "type": "string"
          },
          "to_basis": {
            "description": "Target basis for that slot",
            "type": "string"
          }
        }
      },
      "GetJacobian": {
        "description": "Arguments for GetJacobian action. Returns the Jacobian determinant of a basis change.",
        "type": "object",
        "required": ["basis1", "basis2"],
        "additionalProperties": false,
        "properties": {
          "basis1": {
            "description": "First basis name",
            "type": "string"
          },
          "basis2": {
            "description": "Second basis name",
            "type": "string"
          }
        }
      },
      "BasisChangeQ": {
        "description": "Arguments for BasisChangeQ action. Returns True/False whether a basis change is registered.",
        "type": "object",
        "required": ["from_basis", "to_basis"],
        "additionalProperties": false,
        "properties": {
          "from_basis": {
            "description": "Source basis name",
            "type": "string"
          },
          "to_basis": {
            "description": "Target basis name",
            "type": "string"
          }
        }
      },
      "SetComponents": {
        "description": "Arguments for SetComponents action. Stores component values for a tensor in the given bases.",
        "type": "object",
        "required": ["tensor", "array", "bases"],
        "additionalProperties": false,
        "properties": {
          "tensor": {
            "description": "Name of the abstract tensor to set components for",
            "type": "string"
          },
          "array": {
            "description": "Component values as a nested list (1D for vectors, 2D for matrices, etc.)",
            "oneOf": [
              { "type": "number" },
              {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "number" },
                    { "type": "array", "items": { "type": "number" } }
                  ]
                }
              }
            ]
          },
          "bases": {
            "description": "Basis for each slot (length must match array rank)",
            "type": "array",
            "items": { "type": "string" }
          },
          "weight": {
            "description": "Density weight (default 0)",
            "type": "integer",
            "default": 0
          }
        }
      },
      "GetComponents": {
        "description": "Arguments for GetComponents action. Retrieves component values for a tensor in the given bases.",
        "type": "object",
        "required": ["tensor", "bases"],
        "additionalProperties": false,
        "properties": {
          "tensor": {
            "description": "Name of the tensor to get components for",
            "type": "string"
          },
          "bases": {
            "description": "Basis for each slot",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      },
      "ComponentValue": {
        "description": "Arguments for ComponentValue action. Returns a single component value.",
        "type": "object",
        "required": ["tensor", "indices", "bases"],
        "additionalProperties": false,
        "properties": {
          "tensor": {
            "description": "Name of the tensor",
            "type": "string"
          },
          "indices": {
            "description": "1-based integer indices into the component array",
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "minItems": 1
          },
          "bases": {
            "description": "Basis for each slot",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      },
      "CTensorQ": {
        "description": "Arguments for CTensorQ action. Returns True/False whether component values are stored for the given tensor and bases.",
